aws_region     = "ap-southeast-2"
project_name   = "telco-ods-demo"
key_pair_name  = "your-ec2-key-pair-name"
allowed_ssh_cidr = "0.0.0.0/0"  # Restrict to your IP in production

# MongoDB Atlas (existing cluster)
mongodb_uri = "mongodb+srv://admin:password@democluster.hyszr.mongodb.net/?retryWrites=true&w=majority&appName=DemoCluster"

# Optional: Atlas Admin API (for automated IP whitelisting)
# mongodb_atlas_public_key  = ""
# mongodb_atlas_private_key = ""
# mongodb_atlas_project_id  = ""
